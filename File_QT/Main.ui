     <property name="styleSheet">
      <string notr="true">/* Thanh ray (đường rãnh) */
QSlider::groove:horizontal {
    border: 1px solid #bbb;
    height: 8px; /* Độ dày thanh ray */
    background: #E2C0B2;
    margin: 2px 0;
    border-radius: 4px;
}

/* Nút kéo */
QSlider::handle:horizontal {
    background: #008080; /* Màu xanh đồng bộ của bạn */
    border: 1px solid #005f5f;
    width: 18px;
    height: 18px;
    margin: -7px 0; /* Căn giữa nút kéo so với đường rãnh */
    border-radius: 9px;
}
/* Hiệu ứng khi di chuột qua nút trượt */
QSlider::handle:horizontal:hover {
    background: #27ae60;
}</string>
