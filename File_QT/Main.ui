     <property name="styleSheet">
      <string notr="true">/* Chỉnh viền tổng thể cho ScrollArea */
QScrollArea {
    border: 2px solid #CEC2B1; /* Màu be trung tính đồng bộ với GroupBox */
    border-radius: 5px;        /* Bo góc nhẹ cho hiện đại */
    background-color: #FFFFFF; /* Đảm bảo nền trắng sạch */
}

/* Quan trọng: Chỉnh viền cho vùng nội dung bên trong để không bị đè viền */
QScrollArea #scrollAreaWidgetContents {
    background-color: #FFFFFF;
}</string>
