  <property name="styleSheet">
   <string notr="true">/* Thiết lập cho các GroupBox */
QGroupBox {
    border: 2px solid #CEC2B1;
    border-radius: 8px;
    margin-top: 15px; /* Tạo khoảng trống cho title */
    background-color: #FFFFFF;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center; 
    padding: 2px 20px;
    background-color: #006666;
    color: white;
    font-weight: bold;
    border-radius: 5px;
}
QMainWindow {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1, stop:0 #FFFFFF, stop:1 #DCDCDC);
}</string>
