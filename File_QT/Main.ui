     <string notr="true">QGroupBox {
    /* Đặt màu viền và độ dày */
    border: 2px solid #CEC2B1; 
    border-radius: 8px;
    /* Khoảng cách này cực kỳ quan trọng để tiêu đề không đè lên viền */
    margin-top: 12px; 
    font-weight: bold;
    color: #048687; /* Màu chữ tiêu đề theo bảng màu */
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 2px 15px;
    
    /* Chỉnh màu chữ và nền tiêu đề */

    color: #FFFFFF;           /* Chữ trắng */
